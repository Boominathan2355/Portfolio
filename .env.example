# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.
#
# All values here are PUBLIC by design: they get embedded in the
# built JS bundle and/or index.html. Don't put anything here that
# should stay private (there's nothing private a static portfolio
# needs — EmailJS's "public key" is meant for client-side use).
# ─────────────────────────────────────────────────────────────────

# ─── Contact form (EmailJS) ────────────────────────────────────
# Create a free account at https://www.emailjs.com, add an email
# service + template, then fill these in. Without them the contact
# form stays visibly disabled instead of failing silently.
# Your EmailJS template must use these variable names:
#   {{user_name}} {{user_email}} {{subject}} {{message}}
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ─── Deployment ─────────────────────────────────────────────────
# Canonical site URL, no trailing slash. Drives sitemap.xml,
# robots.txt, and the SEO/OG meta tags below.
VITE_SITE_URL=https://yourdomain.com

# Base path for built assets.
#   Vercel / Netlify / custom domain -> leave blank (defaults to "/")
#   GitHub Pages project site (user.github.io/repo-name) -> "/repo-name/"
VITE_BASE_PATH=

# ─── SEO / index.html meta ──────────────────────────────────────
VITE_SITE_TITLE=Your Name — Your Title
VITE_SITE_DESCRIPTION=A short description of you and the work you do.
VITE_SITE_KEYWORDS=your name, your role, your key skills
VITE_AUTHOR_NAME=Your Name
VITE_AUTHOR_EMAIL=you@example.com
VITE_THEME_COLOR=#3b82f6
VITE_TWITTER_HANDLE=@yourhandle
VITE_GOOGLE_SITE_VERIFICATION=
VITE_GEO_REGION=US-CA
VITE_GEO_PLACENAME=San Francisco, CA
# Path or absolute URL to the social preview image (og:image / twitter:image)
VITE_OG_IMAGE=/profile.jpg
